{
  "name": "visual-progress-tracker",
  "version": "1.0.0",
  "description": "Local-first visual progress tracker for customers, projects, and task handoffs",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "~5.7.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.tonitools.visualprogresstracker",
    "productName": "Visual Progress Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
